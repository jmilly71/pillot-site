---
import { EMAIL_FORM_ACTION } from '../config';

const { label = 'Get notified when Pillot launches', compact = false } = Astro.props;
const uid = `capture-${Math.random().toString(36).slice(2, 8)}`;
---
<div class:list={['capture', { compact }]}>
  {label && <p class="capture-label">{label}</p>}
  <form action={EMAIL_FORM_ACTION || '#'} method="post" class="capture-form" data-endpoint={EMAIL_FORM_ACTION}>
    <label class="sr-only" for={uid}>Email address</label>
    <input
      id={uid}
      type="email"
      name="email"
      required
      placeholder="name@example.com"
      autocomplete="email"
    />
    <button type="submit" class="pill pill--green">Notify me</button>
  </form>
  <p class="capture-msg" role="status" aria-live="polite"></p>
</div>

<script>
  const forms = Array.from(document.querySelectorAll<HTMLFormElement>('.capture-form'));

  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = form.parentElement?.querySelector<HTMLElement>('.capture-msg');
      const button = form.querySelector<HTMLButtonElement>('button');
      const endpoint = form.dataset.endpoint;
      if (!msg || !button) return;

      if (!endpoint) {
        msg.textContent = "Sign-ups aren't open quite yet. Check back soon.";
        msg.className = 'capture-msg visible';
        return;
      }

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      button.disabled = true;
      button.textContent = 'One sec…';
      try {
        // Buttondown's embed endpoint doesn't send CORS headers, so the response
        // is opaque and unreadable. Post no-cors and confirm optimistically;
        // Buttondown sends its own confirmation email as the real receipt.
        await fetch(endpoint, {
          method: 'POST',
          mode: 'no-cors',
          body: new FormData(form),
        });
        form.hidden = true;
        msg.textContent = "You're on the list. Check your inbox to confirm, then we'll email you when Pillot launches.";
        msg.className = 'capture-msg visible success';
      } catch {
        msg.textContent = "Something went wrong. Try again in a minute.";
        msg.className = 'capture-msg visible';
        button.disabled = false;
        button.textContent = 'Notify me';
      }
    });
  });
</script>

<style>
  .capture-label {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 10px;
  }

  .capture.compact .capture-label {
    font-size: 13px;
  }

  .capture-form[hidden] {
    display: none;
  }

  .capture-form {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--card);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 4px 4px 4px 18px;
  }

  .capture-form input {
    border: 0;
    background: transparent;
    color: var(--ink);
    min-width: 170px;
    padding: 8px 0;
  }

  .capture-form input::placeholder {
    color: var(--muted);
  }

  .capture-form input:focus {
    outline: none;
  }

  .capture-form:focus-within {
    outline: 2px solid var(--green);
    outline-offset: 2px;
  }

  .capture-msg {
    display: none;
    font-size: 13px;
    color: var(--body);
    margin-top: 8px;
    max-width: 40ch;
  }

  .capture-msg.visible {
    display: block;
    animation: msg-in 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .capture-msg.success {
    color: var(--green);
    font-weight: 500;
  }

  @keyframes msg-in {
    from {
      opacity: 0;
      translate: 0 4px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .capture-form:not([hidden]) {
      display: flex;
    }

    .capture-form input {
      min-width: 0;
      flex: 1;
    }
  }
</style>
