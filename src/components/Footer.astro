---
import Mark from './Mark.astro';
import CtaSlot from './CtaSlot.astro';
import { SUPPORT_EMAIL } from '../config';
---
<footer>
  <div class="container">
    <div class="inner">
    <div class="top">
      <div class="line">
        <Mark size={40} />
        <p class="tagline">Pillot: a private pillbox for the medications you actually take.</p>
      </div>
      <CtaSlot label="" compact />
    </div>
    <div class="links">
      <a href="/privacy">Privacy policy</a>
      <a href="/terms">Terms</a>
      <a href="/support">Support</a>
      <a href={`mailto:${SUPPORT_EMAIL}`}>Contact</a>
      <p class="disclaimer">Pillot reminds and records. It does not diagnose, dose, or give medical advice.</p>
    </div>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 56px;
  }

  .inner {
    border-top: 2px solid var(--ink);
    padding-block: 28px 36px;
  }

  .top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .line {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .line > :global(svg) {
    flex-shrink: 0;
  }

  .tagline {
    font-family: var(--font-serif);
    font-size: 17px;
  }

  .links {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 40px;
    font-size: 13px;
    color: var(--muted);
  }

  /* Keep each label intact: "Privacy policy" should never break across lines. */
  .links a {
    white-space: nowrap;
  }

  .links a:hover {
    color: var(--ink);
  }

  .disclaimer {
    margin-left: auto;
  }

  /* Drop the disclaimer to its own line well before things get tight, so the
     links keep their natural width and even spacing instead of stretching. */
  @media (max-width: 880px) {
    .disclaimer {
      flex-basis: 100%;
      margin-left: 0;
      margin-top: 12px;
    }
  }

  @media (max-width: 640px) {
    .line {
      align-items: flex-start;
    }
  }
</style>
