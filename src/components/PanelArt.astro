---
const { kind } = Astro.props;

const shots = {
  scan: { src: '/screens/feat-scan.jpg', alt: 'Pillot reading a scanned prescription bottle into a digital label', dark: true },
  notif: { src: '/screens/feat-routine.jpg', alt: 'The daily schedule with scheduled and as-needed medications' },
  hold: { src: '/screens/feat-taken.jpg', alt: 'A dose marked taken with an undo option' },
  prn: { src: '/screens/feat-times.jpg', alt: 'Editing the reminder times for a medication', contain: true },
  week: { src: '/screens/feat-history.jpg', alt: 'The History view filtered by all, taken, missed, and as-needed' },
};

const shot = shots[kind] ?? shots.scan;
---
<div class:list={['art', { 'art-dark': shot.dark, 'art-contain': shot.contain }]}>
  <div class="shot">
    <img src={shot.src} alt={shot.alt} width="820" height="1682" loading="lazy" />
  </div>
</div>

<style>
  .art {
    background: var(--sage-tint);
    border-radius: 14px;
    height: 100%;
    min-height: 220px;
    padding: 34px 34px 0;
    display: flex;
    justify-content: center;
    align-items: stretch;
    overflow: hidden;
  }

  .art-dark {
    background: var(--slate);
  }

  /* Centered, floating card for screens whose key content sits mid-screen. */
  .art-contain {
    padding: 30px;
  }

  .shot {
    width: min(340px, 100%);
    min-height: 0;
    height: 100%;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    box-shadow: 0 6px 36px -10px rgba(26, 26, 26, 0.28);
    background: var(--paper);
  }

  .art-contain .shot {
    border-radius: 16px;
  }

  .shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .art-contain .shot img {
    object-position: center 28%;
  }
</style>
